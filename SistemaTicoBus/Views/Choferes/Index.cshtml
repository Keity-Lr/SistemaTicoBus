@model IEnumerable<SistemaTicoBus.Web.Models.ChoferViewModel>

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Gestión de Personal - TicoBus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            body {
                background-color: #f4f6f8;
                font-family: 'Segoe UI', sans-serif;
            }

            .top-header {
                background-color: #112233;
                color: white;
                padding: 0.75rem 1.5rem;
            }

            .sidebar {
                background-color: #ffffff;
                min-height: 90vh;
                border-right: 1px solid #e9ecef;
            }

            .nav-link {
                color: #5a6578;
                font-weight: 500;
                padding: 0.75rem 1rem;
                border-radius: 0.5rem;
                margin-bottom: 0.25rem;
                display: flex;
                align-items: center;
                text-decoration: none;
            }

                .nav-link.active {
                    background-color: #e8f7f2;
                    color: #0f7654;
                    font-weight: 600;
                }

            .custom-card {
                background: #ffffff;
                border-radius: 1rem;
                border: 1px solid #e9ecef;
                padding: 1.5rem;
            }

            .btn-register {
                background-color: #0f3460;
                color: white;
                font-weight: 600;
                border-radius: 0.5rem;
                padding: 0.75rem;
                border: none;
            }
    </style>
</head>
<body>

    <div class="row g-0 top-header align-items-center shadow-sm">
        <div class="col-12 px-4 fw-bold">TicoBus | <span class="fw-normal small">Consola de Operador</span></div>
    </div>

    <div class="container-fluid p-0">
        <div class="row g-0">
            <div class="col-md-2 p-3 sidebar">
                <ul class="nav flex-column">
                    <li class="nav-item"><a href="@Url.Action("Index", "Choferes")" class="nav-link active"><i class="bi bi-person-video2 me-3"></i> Gestión de Choferes</a></li>
                    <li class="nav-item"><a href="@Url.Action("AdminDashboard", "Account")" class="nav-link"><i class="bi bi-signpost-split me-3"></i> Catálogo de Rutas</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="bi bi-bus-front me-3"></i> Catálogo de Unidades</a></li>
                    <li class="nav-item"><a href="#" class="nav-link"><i class="bi bi-calendar3 me-3"></i> Gestión de Viajes</a></li>
                </ul>
            </div>

            <div class="col-md-10 p-4">

                <div class="bg-white p-3 mb-4 shadow-sm rounded-3 border">
                    <form method="get" action="@Url.Action("Index", "Choferes")" class="row g-2">
                        <div class="col-md-10">
                            <input type="text" name="busqueda" class="form-control border-0" placeholder="Buscar chofer..." value="@ViewBag.Busqueda">
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-dark w-100">Buscar</button>
                        </div>
                    </form>
                </div>

                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="custom-card shadow-sm">
                            <h5 id="formTitle" class="fw-bold mb-4">Registrar Nuevo Chofer</h5>
                            <form id="choferForm" method="post" action="@Url.Action("Create", "Choferes")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Identificacion" id="inputIdentificacion" />
                                <div class="mb-3"><input type="text" name="Identificacion" id="fId" class="form-control" placeholder="Cédula" required></div>
                                <div class="mb-3"><input type="text" name="Nombre" id="fNombre" class="form-control" placeholder="Nombre" required></div>
                                <div class="mb-3"><input type="text" name="Apellidos" id="fApellidos" class="form-control" placeholder="Apellidos" required></div>
                                <div class="mb-3"><input type="email" name="Correo" id="fCorreo" class="form-control" placeholder="Correo" required></div>
                                <button type="submit" id="btnSubmit" class="btn btn-register w-100">Guardar Chofer</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="custom-card shadow-sm">
                            <h5 class="fw-bold mb-4">Listado de Choferes</h5>
                            <table class="table align-middle">
                                <thead><tr class="text-secondary small"><th>ID</th><th>Nombre</th><th>Correo</th><th class="text-end">Acciones</th></tr></thead>
                                <tbody>
                                    @foreach (var c in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold">@c.Identificacion</td>
                                            <td>@c.Nombre @c.Apellidos</td>
                                            <td>@c.Correo</td>
                                            <td class="text-end">
                                                <button type="button" class="btn btn-sm btn-outline-warning" onclick="editar('@c.Identificacion', '@c.Nombre', '@c.Apellidos', '@c.Correo')"><i class="bi bi-pencil"></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
            function editar(id, nom, ape, cor) {
                document.getElementById('formTitle').innerText = "Editar Chofer";
                document.getElementById('choferForm').action = "/Choferes/Edit";
                document.getElementById('fId').value = id;
                document.getElementById('fId').readOnly = true;
                document.getElementById('fNombre').value = nom;
                document.getElementById('fApellidos').value = ape;
                document.getElementById('fCorreo').value = cor;
                document.getElementById('btnSubmit').innerText = "Actualizar";
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
    </script>
</body>
</html>