@model List<SistemaTicoBus.Web.Models.ChoferViewModel>

@{
    Layout = null;
    string busqueda = ViewBag.Busqueda as string ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Choferes - TicoBus 2025</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            body {
                margin: 0;
                min-height: 100vh;
                background-color: #d1d5db;
                position: relative;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                overflow-x: hidden;
            }

                body::before {
                    content: "";
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url('/images/fondo-bus.jpg');
                    background-size: cover;
                    background-position: center;
                    opacity: 0.15;
                    z-index: 1;
                }

            .logo-esquina {
                position: fixed;
                top: 20px;
                left: 20px;
                z-index: 10;
                width: 120px;
                height: auto;
            }

            .page-wrapper {
                position: relative;
                z-index: 5;
                width: 100%;
                max-width: 1150px;
                margin: 0 auto;
                padding: 90px 20px 40px;
            }

            .main-card {
                background: #ffffff;
                padding: 32px;
                border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            }

            .logo-central {
                width: 55px;
                margin-bottom: 10px;
            }

            .btn-ticobus {
                background-color: #474f5e;
                color: white;
                border: none;
                border-radius: 6px;
                font-weight: bold;
                padding: 10px 16px;
                transition: background 0.2s;
            }

                .btn-ticobus:hover {
                    background-color: #353b47;
                    color: white;
                }

            .btn-outline-ticobus {
                border: 1px solid #474f5e;
                color: #474f5e;
                border-radius: 6px;
                font-weight: bold;
                padding: 9px 16px;
            }

                .btn-outline-ticobus:hover {
                    background-color: #474f5e;
                    color: white;
                }

            .table thead {
                background-color: #474f5e;
                color: white;
            }

            .section-title {
                color: #212529;
                font-weight: 700;
            }

            .small-muted {
                color: #6c757d;
                font-size: 13px;
            }

            .logout-button {
                white-space: nowrap;
            }
    </style>
</head>
<body>
    <img src="/images/logo-ticobus.png" class="logo-esquina" alt="TicoBus Logo">

    <div class="page-wrapper">
        <div class="main-card">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div style="width: 145px;"></div>

                <div class="text-center">
                    <img src="/images/logo-ticobus.png" class="logo-central" alt="Logo Central">
                    <h3 class="section-title m-0">Gestión de Choferes</h3>
                    <p class="small-muted mb-0">Administración de empleados que operan las unidades de TicoBus.</p>
                </div>

                <div class="text-end" style="width: 145px;">
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary btn-sm logout-button">
                        <i class="fa-solid fa-right-from-bracket me-1"></i>Cerrar sesión
                    </a>
                </div>
            </div>

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success small" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i>@TempData["MensajeExito"]
                </div>
            }

            @if (TempData["MensajeError"] != null)
            {
                <div class="alert alert-danger small" role="alert">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>@TempData["MensajeError"]
                </div>
            }

            <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                <form asp-action="Index" method="get" class="d-flex gap-2 flex-grow-1">
                    <input type="text"
                           name="busqueda"
                           value="@busqueda"
                           class="form-control"
                           placeholder="Buscar por nombre o apellido" />

                    <button type="submit" class="btn btn-ticobus">
                        <i class="fa-solid fa-magnifying-glass me-1"></i>Buscar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Limpiar
                    </a>
                </form>

                <a asp-action="Create" class="btn btn-ticobus">
                    <i class="fa-solid fa-plus me-1"></i>Agregar chofer
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Identificación</th>
                            <th>Nombre</th>
                            <th>Apellidos</th>
                            <th>Correo</th>
                            <th>Usuario</th>
                            <th class="text-center" style="width: 220px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var chofer in Model)
                            {
                                <tr>
                                    <td>@chofer.Identificacion</td>
                                    <td>@chofer.Nombre</td>
                                    <td>@chofer.Apellidos</td>
                                    <td>@chofer.Correo</td>
                                    <td>@chofer.NombreUsuario</td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Edit"
                                                   asp-route-id="@chofer.Identificacion"
                                                   class="btn btn-sm btn-outline-ticobus">
                                                <i class="fa-solid fa-pen-to-square me-1"></i>Editar
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-id="@chofer.Identificacion"
                                                  method="post"
                                                  onsubmit="return confirm('¿Desea eliminar este chofer? Solo se eliminará si no tiene viajes registrados.');">
                                                @Html.AntiForgeryToken()

                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="fa-solid fa-trash me-1"></i>Eliminar
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    No se encontraron choferes registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <a asp-controller="Account" asp-action="AdminDashboard" class="text-decoration-none small fw-bold text-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i>Volver al panel
                </a>
            </div>
        </div>
    </div>
</body>
</html>