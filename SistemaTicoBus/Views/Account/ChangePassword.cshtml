@model SistemaTicoBus.Web.Models.ChangePasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cambio de Clave - TicoBus 2025</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                margin: 0;
                min-height: 100vh;
                background-color: #d1d5db;
                position: relative;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                overflow: hidden;
            }

            body::before {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-image: url('/images/fondo-bus.jpg');
                background-size: cover;
                background-position: center;
                opacity: 0.15;
                z-index: 1;
            }

            .logo-esquina {
                position: fixed;
                top: 20px;
                left: 20px;
                z-index: 10;
                width: 120px;
                height: auto;
            }

            .login-wrapper {
                position: relative;
                z-index: 5;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .login-card {
                background: #ffffff;
                width: 100%;
                max-width: 390px;
                padding: 35px 32px;
                border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.1);
                text-align: center;
            }

            .logo-central {
                width: 55px;
                margin-bottom: 12px;
            }

            .titulo {
                font-size: 24px;
                font-weight: 700;
                color: #212529;
                margin-bottom: 4px;
            }

            .subtitulo {
                color: #6c757d;
                font-size: 14px;
                margin-bottom: 26px;
            }

            .form-label {
                font-size: 12px;
                font-weight: 700;
                color: #6c757d;
                text-align: left;
                display: block;
                margin-bottom: 6px;
            }

            .form-control {
                border-radius: 6px;
                padding: 11px;
            }

            .btn-ticobus {
                background-color: #474f5e;
                color: white;
                width: 100%;
                padding: 12px;
                border: none;
                border-radius: 6px;
                font-weight: bold;
                margin-top: 8px;
            }

            .btn-ticobus:hover {
                background-color: #353b47;
                color: white;
            }

            .link-secondary {
                display: block;
                margin-top: 16px;
                color: #474f5e;
                font-size: 14px;
                font-weight: 600;
                text-decoration: none;
            }

            .link-secondary:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <img src="/images/logo-ticobus.png" class="logo-esquina" alt="TicoBus Logo">

    <div class="login-wrapper">
        <div class="login-card">
            <img src="/images/logo-ticobus.png" class="logo-central" alt="Logo Central">

            <h1 class="titulo">Cambio de clave</h1>
            <p class="subtitulo">Ingrese su usuario, clave actual y nueva clave.</p>

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success py-2 small text-start" role="alert">
                    @TempData["MensajeExito"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small text-start" role="alert">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3 text-start">
                    <label asp-for="Nombre" class="form-label">NOMBRE</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ejemplo: chofer.mario" autocomplete="off" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="mb-3 text-start">
                    <label asp-for="ClaveActual" class="form-label">CLAVE ACTUAL</label>
                    <input asp-for="ClaveActual" type="password" class="form-control" placeholder="Clave actual" />
                    <span asp-validation-for="ClaveActual" class="text-danger small"></span>
                </div>

                <div class="mb-3 text-start">
                    <label asp-for="NuevaClave" class="form-label">NUEVA CLAVE</label>
                    <input asp-for="NuevaClave" type="password" class="form-control" placeholder="Nueva clave" />
                    <span asp-validation-for="NuevaClave" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-ticobus">Actualizar clave</button>
            </form>

            <a asp-controller="Account" asp-action="Login" class="link-secondary">Volver al login</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>